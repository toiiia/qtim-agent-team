{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Read(./.env*)",
      "Edit(./.env*)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Напоминание: pnpm typecheck перед передачей задачи дальше.'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
